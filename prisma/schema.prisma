generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id           String         @id @db.Uuid
  email        String?
  
  items        items[]
  accounts     accounts[]
  transactions transactions[]
  investment_holdings investment_holdings[]
  investment_transactions investment_transactions[]
  securities securities[]
  tags         tags[]
  system_logs  system_logs[]
  budget_rules budget_rules[]
}

model items {
  id                      String         @id
  user_id                 String         @db.Uuid
  access_token            String?
  transaction_cursor      String?
  institution_id          String?
  institution_name        String?
  created_at              DateTime?
  consented_products      Json?
  consented_data_scopes   Json?
  consented_use_cases     Json?
  consent_expiration_time String?
  available_products      Json?
  billed_products         Json?
  products                Json?
  transactions_sync_lock_until DateTime?
  
  accounts                accounts[]
  users                   users          @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactions            transactions[]
  investment_holdings     investment_holdings[]
  investment_transactions investment_transactions[]
  securities              securities[]
}

model accounts {
  id              String         @id
  item_id         String?
  user_id         String         @db.Uuid
  name            String?
  official_name   String?
  type            String?
  subtype         String?
  balances        Json?
  mask            String?
  holder_category String?
  
  items           items?         @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users          @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transactions    transactions[]
  investment_holdings investment_holdings[]
  investment_transactions investment_transactions[]
  securities       securities[]
}

model transactions {
  id                                 String   @id
  user_id                            String   @db.Uuid
  item_id                            String
  account_id                         String
  name                               String?
  original_description               String?
  merchant_name                      String?
  amount                             Float?
  iso_currency_code                  String?
  counterparties                     Json?
  datetime                           DateTime?
  authorized_datetime                DateTime?
  location                           Json?
  pending                            Boolean?
  personal_finance_category          Json?
  personal_finance_category_icon_url String?
  is_removed                         Boolean? @default(false)
 
  accounts                           accounts @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items                              items    @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transaction_meta                   transaction_meta?
  users                              users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model investment_holdings {
  account_id                 String
  security_id                String
  user_id                    String   @db.Uuid
  item_id                    String
  institution_price          Float
  institution_price_as_of    DateTime?
  institution_price_datetime DateTime?
  institution_price_date     DateTime
  institution_value          Float
  cost_basis                 Float?
  quantity                   Float
  iso_currency_code          String?
  unofficial_currency_code   String?
  currency_code              String?
  vested_quantity            Float?
  vested_value               Float?
  raw_payload                Json?
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  accounts  accounts   @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items     items      @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  securities securities @relation(fields: [security_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users     users      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([account_id, security_id])
  @@index([user_id, item_id])
}

model investment_transactions {
  id                       String   @id
  user_id                  String   @db.Uuid
  item_id                  String
  account_id               String
  security_id              String?
  date                     DateTime
  plaid_datetime           DateTime?
  datetime                 DateTime
  name                     String
  quantity                 Float
  amount                   Float
  price                    Float
  fees                     Float?
  type                     String
  subtype                  String
  iso_currency_code        String?
  unofficial_currency_code String?
  currency_code            String?
  raw_payload              Json?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  accounts  accounts    @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items     items       @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  securities securities? @relation(fields: [security_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users     users       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id, datetime])
  @@index([account_id, security_id])
}

model securities {
  id                       String   @id
  user_id                  String   @db.Uuid
  item_id                  String
  account_id               String
  institution_security_id  String?
  institution_id           String?
  proxy_security_id        String?
  name                     String?
  ticker_symbol            String?
  is_cash_equivalent       Boolean?
  type                     String?
  subtype                  String?
  close_price              Float?
  close_price_as_of        DateTime?
  update_datetime          DateTime?
  iso_currency_code        String?
  unofficial_currency_code String?
  currency_code            String?
  market_identifier_code   String?
  sector                   String?
  industry                 String?
  option_contract          Json?
  fixed_income             Json?
  raw_payload              Json?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  accounts accounts @relation(fields: [account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items    items    @relation(fields: [item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users    users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  investment_holdings investment_holdings[]
  investment_transactions investment_transactions[]

  @@index([user_id, item_id])
  @@index([ticker_symbol])
}

model transaction_meta {
  transaction_id         String  @id
  account_transfer_group String?
  bucket_1_tag_id        Int?
  bucket_2_tag_id        Int?

  transaction  transactions @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  bucket_1_tag tags?        @relation("Bucket1Tag", fields: [bucket_1_tag_id], references: [id])
  bucket_2_tag tags?        @relation("Bucket2Tag", fields: [bucket_2_tag_id], references: [id])
  meta_tags    transaction_tags[]

  @@index([account_transfer_group])
}

enum TagType {
  income_bucket_1
  income_bucket_2
  spending_bucket_1
  spending_bucket_2
  meta
}

enum BudgetRuleType {
  flat_rate
  percent_of_income
}

enum CalendarWindow {
  week
  month
}

enum RolloverOption {
  none
  surplus
  deficit
  both
}

enum BudgetRuleSourceType {
  tag
  detected_category
}

model tags {
  id      Int     @id @default(autoincrement())
  name    String
  type    TagType
  user_id String  @db.Uuid
  color   String?

  bucket_1_meta     transaction_meta[]  @relation("Bucket1Tag")
  bucket_2_meta     transaction_meta[]  @relation("Bucket2Tag")
  transaction_tags  transaction_tags[]
  budget_rules      budget_rules[]
  users             users               @relation(fields: [user_id], references: [id])

  @@unique([name, user_id])
}

model transaction_tags {
  transaction_id String
  tag_id         Int

  transaction_meta transaction_meta @relation(fields: [transaction_id], references: [transaction_id], onDelete: Cascade)
  tag              tags             @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([transaction_id, tag_id])
}

model budget_rules {
  id               Int            @id @default(autoincrement())
  user_id          String         @db.Uuid
  rule_source_type BudgetRuleSourceType @default(tag)
  tag_id           Int?
  detected_category String?
  name             String
  start_date       DateTime
  type             BudgetRuleType
  flat_amount      Float?
  percent          Float?
  calendar_window  CalendarWindow
  rollover_options RolloverOption
  cache            Json?

  users users @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tag   tags? @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@index([user_id, detected_category])
}

model system_logs {
  id          Int      @id @default(autoincrement())
  user_id     String   @db.Uuid
  type        String
  level       Int
  metadata    Json?
  raw_payload Json?
  timestamp   DateTime @default(now())

  users users @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([type, timestamp])
}
